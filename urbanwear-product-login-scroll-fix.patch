+  font-weight: 950;
+}
+
+.auth-card input {
+  min-height: 52px !important;
+  border-radius: 18px !important;
+  background: #f8fafc !important;
+  border-color: #e2e8f0 !important;
+}
+
+.auth-card input:focus {
+  background: #fff !important;
+  border-color: #0f3d36 !important;
+  box-shadow: 0 0 0 4px rgba(15, 61, 54, 0.1) !important;
+}
+
+.auth-submit {
+  min-height: 52px;
+  border-radius: 18px !important;
+  background: linear-gradient(135deg, #0f3d36, #111827) !important;
