{
  "name": "urbanwear-mern",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "client": "vite --config client/vite.config.js",
    "dev": "node scripts/dev.js",
    "server": "node server/server.js",
    "prebuild": "node scripts/ensure-deps.js",
    "build": "vite build --config client/vite.config.js",
    "lint": "eslint .",
    "preview": "vite preview --config client/vite.config.js",
    "start": "node server/server.js",
    "render-build": "npm ci && npm run build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-react": "^4.7.0",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongoose": "^8.9.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "tailwindcss": "^4.2.4",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "description": "UrbanWear MERN fashion ecommerce platform with size/color variants, wishlist, collections, checkout, admin inventory, delivery tracking, and SRS API aliases."
